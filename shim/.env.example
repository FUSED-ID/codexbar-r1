# Copy to .env and `set -a; source .env; set +a` before running the shim.

# Shared secret. Generate with: openssl rand -hex 16
CODEXBAR_SHIM_TOKEN=replace-me

# Machines to aggregate. Hub is local; peers are reachable over Tailscale.
# Key = label shown on the R1 tab. Value = that machine's `codexbar serve` base URL.
CODEXBAR_UPSTREAMS={"M4":"http://127.0.0.1:8080","M1":"http://m1:8080"}

# codex + claude
CODEXBAR_PROVIDER=both

# Bind loopback only; Tailscale Funnel publishes it.
CODEXBAR_SHIM_HOST=127.0.0.1
CODEXBAR_SHIM_PORT=8088
